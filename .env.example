# =============================================================================
# SocialHub backend - sample environment configuration.
# Copy to `.env` and adjust. NEVER commit real credentials.
# Load it into your shell (e.g. `set -a; . ./.env; set +a`) before running,
# or configure these in your IDE / deployment platform.
# =============================================================================

# Active Spring profile: dev | prod
SPRING_PROFILES_ACTIVE=dev

# --- PostgreSQL ---
DB_URL=jdbc:postgresql://localhost:5432/socialhub
DB_USERNAME=socialhub
DB_PASSWORD=socialhub

# --- HikariCP connection pool ---
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2

# --- HTTP server ---
SERVER_PORT=8080

# --- CORS (comma-separated origins allowed to call the API) ---
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- Secrets at rest ---
# Strong, stable secret used to encrypt integration access tokens (AES-GCM).
# Rotating this invalidates previously stored tokens.
APP_ENCRYPTION_SECRET=change-me-dev-secret-please-rotate

# --- Authentication (JWT) ---
# Strong, stable HMAC signing secret. Rotating it invalidates all issued tokens.
AUTH_JWT_SECRET=change-me-dev-jwt-secret-please-rotate
# AUTH_ACCESS_TOKEN_TTL=PT30M
# AUTH_REFRESH_TOKEN_TTL=P14D
# Initial admin seeded on startup (disable once a real admin exists / in prod).
AUTH_SEED_ADMIN_ENABLED=true
AUTH_SEED_ADMIN_EMAIL=admin@socialhub.local
AUTH_SEED_ADMIN_PASSWORD=admin12345

# --- Tenancy (default org for new self-registered users) ---
DEFAULT_ORGANIZATION_ID=1

# --- Facebook integration (Graph API infrastructure only) ---
# Each user provides their OWN Meta App ID + Secret in the app; those are stored
# encrypted in the DB, per user. There is NO global app id/secret here.
# FACEBOOK_GRAPH_BASE_URL=https://graph.facebook.com
# FACEBOOK_GRAPH_API_VERSION=v25.0

# --- SSO / OAuth2 (placeholders, not wired yet) ---
# TODO[SSO]: set these once an OIDC provider is configured.
# OAUTH2_ISSUER_URI=
# OAUTH2_CLIENT_ID=
# OAUTH2_CLIENT_SECRET=
