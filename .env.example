# =============================================================================
# SocialHub backend - sample environment configuration.
# Copy to `.env` and adjust. NEVER commit real credentials.
# Load it into your shell (e.g. `set -a; . ./.env; set +a`) before running,
# or configure these in your IDE / deployment platform.
# =============================================================================

# Active Spring profile: dev | prod
SPRING_PROFILES_ACTIVE=dev

# --- PostgreSQL ---
DB_URL=jdbc:postgresql://localhost:5432/socialhub
DB_USERNAME=socialhub
DB_PASSWORD=socialhub

# --- HikariCP connection pool ---
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2

# --- HTTP server ---
SERVER_PORT=8080

# --- CORS (comma-separated origins allowed to call the API) ---
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- Secrets at rest ---
# Strong, stable secret used to encrypt integration access tokens (AES-GCM).
# Rotating this invalidates previously stored tokens.
APP_ENCRYPTION_SECRET=change-me-dev-secret-please-rotate

# --- Tenancy (dev fallback until SSO provides the org) ---
DEFAULT_ORGANIZATION_ID=1

# --- Facebook integration (OAuth / Graph API) ---
# App id is also needed by the frontend (Angular environment). The secret is
# server-side ONLY and must never be sent to the browser.
FACEBOOK_APP_ID= 1435931321914155
FACEBOOK_APP_SECRET= 05343069cf6b9fe38ecb75b5cf8eb57e
FACEBOOK_REDIRECT_URI=http://localhost:4200/settings/social-integrations
FACEBOOK_SCOPES=pages_show_list,pages_read_engagement,pages_manage_posts,pages_read_user_content
# FACEBOOK_GRAPH_API_VERSION=v25.0

# --- SSO / OAuth2 (placeholders, not wired yet) ---
# TODO[SSO]: set these once an OIDC provider is configured.
# OAUTH2_ISSUER_URI=
# OAUTH2_CLIENT_ID=
# OAUTH2_CLIENT_SECRET=
