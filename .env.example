# =============================================================================
# SocialHub backend - sample environment configuration.
# Copy to `.env` and adjust. NEVER commit real credentials.
# Load it into your shell (e.g. `set -a; . ./.env; set +a`) before running,
# or configure these in your IDE / deployment platform.
# =============================================================================

# Active Spring profile: dev | prod
SPRING_PROFILES_ACTIVE=dev

# --- PostgreSQL ---
DB_URL=jdbc:postgresql://localhost:5432/socialhub
DB_USERNAME=socialhub
DB_PASSWORD=socialhub

# --- HikariCP connection pool ---
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2

# --- HTTP server ---
SERVER_PORT=8080

# --- CORS (comma-separated origins allowed to call the API) ---
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- SSO / OAuth2 (placeholders, not wired yet) ---
# TODO[SSO]: set these once an OIDC provider is configured.
# OAUTH2_ISSUER_URI=
# OAUTH2_CLIENT_ID=
# OAUTH2_CLIENT_SECRET=
